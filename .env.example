TSB_URL=
TSB_AUTH=NONE

# Optional for TOKEN auth:
# TSB_BEARER_TOKEN=

# Optional for CERT auth:
# TSB_CERT_PATH=../testHelpers/tsb-integration-test-client.crt
# TSB_KEY_PATH=../testHelpers/tsb-integration-test-client.key

# Optional async request signing key pair. Use either JSON:
# TSB_APPLICATION_KEY_PAIR={"privateKey":"","publicKey":""}

# Or split values:
# TSB_APPLICATION_PRIVATE_KEY=
# TSB_APPLICATION_PUBLIC_KEY=

# Optional API keys. Use either JSON:
# TSB_API_KEYS={"KeyManagementToken":[""],"KeyOperationToken":[""],"ServiceToken":[""],"ApproverToken":[""]}

# Or split comma-separated values:
# TSB_KEY_MANAGEMENT_TOKEN=
# TSB_KEY_OPERATION_TOKEN=
# TSB_SERVICE_TOKEN=
# TSB_APPROVER_TOKEN=
# TSB_APPROVER_KEY_MANAGEMENT_TOKEN=
